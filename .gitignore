# ---- Python (bytecode / caches) ----
__pycache__/
*.py[cod]
*$py.class

# ---- Virtual environments ----
.venv/
venv/
env/
dvc_env/

# ---- Jupyter / IPython ----
.ipynb_checkpoints/

# ---- Python tooling caches ----
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/

# ---- OS / editor ----
.DS_Store
Thumbs.db

# ---- Secrets / env files ----
.env
.env.*

# ---- DVC ----
# Keep DVC metadata (dvc.yaml, dvc.lock, *.dvc) in Git.
# Ignore DVC internal cache/temp.
.dvc/cache/
.dvc/tmp/

# ---- Data ----
# Datasets should typically be tracked by DVC, not Git.
# Remove these lines if you intentionally want to commit CSVs.
data/**
!data/**/.gitignore
!data/**/*.dvc
